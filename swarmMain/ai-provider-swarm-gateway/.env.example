# AI Provider Swarm Gateway — Environment Variables
# Copy this file to .env and fill in YOUR OWN legitimate API keys.
# NEVER commit .env to version control.
# Each key must be obtained from the provider's official website.
# See PROVIDER_REGISTRY.md for sign-up links for each provider.

# OpenAI (requires payment — no free tier as of 2026)
OPENAI_API_KEY=

# Anthropic Claude (requires payment — no free tier as of 2026)
ANTHROPIC_API_KEY=

# Google Gemini — FREE permanent tier available at https://aistudio.google.com
GOOGLE_API_KEY=

# DeepSeek — 5M token one-time credit on signup
DEEPSEEK_API_KEY=

# Qwen / Alibaba Cloud — 90-day one-time credit (Singapore region only)
QWEN_API_KEY=

# Zhipu GLM — free tier undocumented, verify before use
ZHIPU_GLM_API_KEY=

# Moonshot Kimi — free tier unknown for international users; use Groq for Kimi K2
MOONSHOT_KIMI_API_KEY=

# Mistral AI — FREE permanent tier at https://console.mistral.ai (1B tokens/month)
MISTRAL_API_KEY=

# Groq — FREE permanent tier at https://console.groq.com (no credit card)
GROQ_API_KEY=

# Together AI — NO FREE TIER. Requires $5 minimum deposit.
TOGETHER_API_KEY=

# Fireworks AI — ~$1 one-time credit only
FIREWORKS_API_KEY=

# OpenRouter — free models available at https://openrouter.ai
OPENROUTER_API_KEY=

# Hugging Face — minimal free credits ($0.10/month)
HUGGINGFACE_API_TOKEN=

# Replicate — check current pricing
REPLICATE_API_TOKEN=

# Cohere — 1000 req/month free at https://dashboard.cohere.com
COHERE_API_KEY=

# Cerebras — FREE permanent tier at https://cloud.cerebras.ai (1M tokens/day)
CEREBRAS_API_KEY=

# Perplexity — API free tier unconfirmed
PERPLEXITY_API_KEY=

# xAI Grok — $25 one-time credit
XAI_API_KEY=

# NVIDIA NIM — 1000 developer credits
NVIDIA_API_KEY=

# Cloudflare Workers AI — use account ID + API token from Cloudflare dashboard
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
