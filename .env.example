# SwarmGraph environment example. Do not put real secrets in this file.

# Tenant / local state
AI_PROVIDER_GATEWAY_TENANT=
AI_PROVIDER_GATEWAY_USAGE_PATH=
AI_PROVIDER_GATEWAY_REVIEWER_ID=

# LLM dispatch
HIVE_SWARM_LLM_BACKEND=stub
HIVE_SWARM_LLM_PROVIDER=9router
HIVE_SWARM_LLM_MODEL=
HIVE_SWARM_LLM_STREAM=
HIVE_SWARM_COST_TRACKING=

# Audit signing. Production should use a 32+ byte random secret and fail-closed config.
HIVE_SWARM_AUDIT_SECRET=

# Encrypted local account vault
AI_PROVIDER_GATEWAY_VAULT_KEY=

# 9router
AI_PROVIDER_GATEWAY_9ROUTER_API_KEY=
AI_PROVIDER_GATEWAY_9ROUTER_BASE_URL=
AI_PROVIDER_GATEWAY_9ROUTER_MODEL=
AI_PROVIDER_GATEWAY_9ROUTER_TIMEOUT=
AI_PROVIDER_GATEWAY_9ROUTER_ALLOWED_HOSTS=
AI_PROVIDER_GATEWAY_9ROUTER_ALLOW_OPENAI_KEY=

# 9router compatibility aliases. Prefer AI_PROVIDER_GATEWAY_9ROUTER_API_KEY in production.
ROUTER_API_KEY=
NINEROUTER_API_KEY=
KILO_CODE_API_KEY=

# Provider keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
XAI_API_KEY=
AI_PROVIDER_GROK_API_KEY=
QWEN_API_KEY=
MOONSHOT_KIMI_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
ZHIPU_GLM_API_KEY=
