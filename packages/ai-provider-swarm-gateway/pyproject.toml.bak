[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[project]
name = "ai-provider-swarm-gateway"
version = "0.1.0"
description = "AI provider routing gateway"
requires-python = ">=3.11"
dependencies = [
  "pydantic>=2.7.0",
  "pyyaml>=6.0",
  "typer>=0.12.0",
  "rich>=13.0",
  "python-dotenv>=1.0",
]

[project.optional-dependencies]
test = ["pytest>=8.0", "pytest-cov>=5.0"]

[project.scripts]
ai-provider-gateway = "ai_provider_swarm_gateway.cli:app"

[tool.hatch.build.targets.wheel]
packages = ["src/ai_provider_swarm_gateway"]

[tool.pytest.ini_options]
testpaths = ["tests"]
addopts = "-q --tb=short"
